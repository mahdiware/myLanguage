/* array[index] and number */
print("1) array[index] and number: \n");
num = 5;
num[2] = 10;
float = 2.43;

print("	num = ", num, "\n");
print("	num[50] = ", num[2], "\n");
print("	float = ", float, "\n");

/* String */
print("2) String: \n");
name = "mohamed";

print("	name = ", name);
print "\n";

/*condition-if-else*/
print("3) condition-if-else: \n");
a = 50;

print("	if-elif-else where a = ", a);

if (a == 10){
	print("	a==10 ✔\n");
} elif(a == 20) {
	print("	a==20 ✔\n");
} else {
	print("	else ✔\n");
}

/* do-while-loop*/
print("4) do-while-loop: \n");

dowhile = 1;
do {
    print("	do-while-loop: ", dowhile, "\n");
    
    dowhile = dowhile + 1;
} while (dowhile <= 10);

/* while-loop */
print("\n5) while-loop: \n");
whileloop = 1;
while (whileloop <= 10) {
    print("	do-while-loop: ", whileloop, "\n");
    
    whileloop = whileloop + 1;
}

/* function */
print("\n6) function: \n");
function funcname(){
	print("	this is function\n");
}
funcname();



